<section class="flex flex-col w-full">
  <span class="text-white text-center font-semibold mt-5"><%= current_user.email %></span>
  <div class="flex items-center justify-center mt-2">
    <%= button_to 'Log Out', destroy_user_session_path, method: :delete, class: 'px-3 py-1 text-white bg-red-700 rounded font-semibold text-sm'%>
  </div>
  <div>
    <h3 class="text-white font-bold text-center mb-2">My Rooms</h3>
  </div>

  <div class="flex flex-col px-5 gap-2 w-full" id="rooms">
    <% if current_user.rooms.any? %>
      <% current_user.rooms.all.each do |room| %>
        <%= render 'shared/room', room: room %>
      <% end %>
    <% else %>
      <p class="text-white font-semibold text-sm text-center">You have no rooms yet.</p>
    <% end %>
  </div>
</section>