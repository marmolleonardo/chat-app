<main class="min-h-screen bg-gray-100 dark:bg-blue-950 flex flex-col justify-center items-center py-8">
  <section class="flex flex-col items-center">
    <%= image_tag '5041093.png', width: 100 %>
    <h1 class="text-blue-900 dark:text-white text-4xl font-bold mb-2">ChatApp</h1>
    <p class="text-gray-700 dark:text-white font-semibold">This is the chat app with RoR using Stimulus</p>
  </section>

  <section class="w-full max-w-md bg-white dark:bg-white/10 rounded-xl shadow-lg p-8 flex flex-col items-center">
    <%= form_for(resource, as: resource_name, url: session_path(resource_name), class: 'w-full space-y-5') do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="flex flex-row items-center gap-1 my-2">
        <%= f.label :email, class: 'text-white font-semibold text-sm w-28' %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: 'flex-1 rounded px-3 py-2 bg-white text-gray-900 dark:bg-white/80 dark:text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500' %>
      </div>

      <div class="flex flex-row items-center gap-1 my-2">
        <%= f.label :password, class: 'text-white font-semibold text-sm w-28' %>
        <%= f.password_field :password, autocomplete: "current-password", class: 'flex-1 rounded px-3 py-2 bg-white text-gray-900 dark:bg-white/80 dark:text-gray-900 focus:outline-none focus:ring-2 focus:ring-blue-500' %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex flex-row items-center gap-1 my-2">
          <span class="w-24"></span>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: 'rounded border-gray-300 text-blue-600 shadow-sm focus:ring focus:ring-blue-500 focus:ring-opacity-50' %>
            <%= f.label :remember_me, class: 'text-white font-semibold text-sm' %>
          </div>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "Log in", class: 'w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded transition-colors duration-200' %>
      </div>
    <% end %>

    <div class="mt-4 w-full flex justify-center">
      <%= render "devise/shared/links" %>
    </div>
  </section>
</main>
