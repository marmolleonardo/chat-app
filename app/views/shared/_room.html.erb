<%= turbo_frame_tag "room_#{room.id}" do %>
  <div class="px-3 py-2 bg-blue-700 rounded text-white text-sm font-semibold hover:bg-blue-600">
    <%= link_to room_path(room), class:"font-semibold text-white text-sm", data: { turbo_frame: 'rooms_controller' } do %>
    <%= room.name %>
  <% end %>
  <%= link_to 'Edit Room', edit_room_path(room) %>
  </div>
<% end %>